# Requis UNIQUEMENT pour les outils licence (validate/status/grace/update).
# Secret HMAC livré avec votre licence Codinfy — ne JAMAIS le committer.
CODINFY_LICENSE_SECRET=

# Optionnel : surcharge de l'API (sandbox / instance locale)
# CODINFY_API_BASE=https://api.codinfy.com/api
# CODINFY_SITE_BASE=https://codinfy.com

# Optionnel : clé API publique pk_live_… / pk_sandbox_…
# Transmise en X-Codinfy-Api-Key ; l'émission de clés arrive avec le
# portail développeur Codinfy.
# CODINFY_API_KEY=
