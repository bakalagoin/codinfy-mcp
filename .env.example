# Required: public API key for Codinfy API
# Get one at https://codinfy.com/admin/parametres/api-s
# Prefix: pk_live_... (production) or pk_sandbox_... (sandbox)
CODINFY_API_KEY=

# Optional: override the API base URL (defaults to https://api.codinfy.com)
# CODINFY_API_BASE_URL=https://api.codinfy.com

# Optional: request timeout in ms (default 15000)
# CODINFY_API_TIMEOUT_MS=15000
